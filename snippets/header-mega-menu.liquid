{% comment %}
  Renders the desktop mega menu with per-item layout overrides via section blocks.

  Accepts:
  - blocks: section.blocks (for menu_item_override blocks)

  Usage:
  {% render 'header-mega-menu', blocks: section.blocks %}
{% endcomment %}

{%- liquid
  assign default_type = section.settings.menu_type_desktop | default: 'mega'
-%}

<nav class="header__inline-menu">
  <ul class="list-menu list-menu--inline" role="list">
    {%- for link in section.settings.menu.links -%}

      {%- liquid
        # Find a block override for this menu item by handle
        assign item_type = default_type
        assign item_mega_layout = 'columns'
        assign item_mega_columns = 4
        assign item_mega_image = nil
        assign item_mega_heading = nil
        assign item_mega_link = nil
        assign item_show_desc = false

        for block in blocks
          if block.type == 'menu_item_override' and block.settings.menu_item_handle == link.handle
            if block.settings.menu_type != 'default'
              assign item_type = block.settings.menu_type
            endif
            assign item_mega_layout   = block.settings.mega_layout   | default: 'columns'
            assign item_mega_columns  = block.settings.mega_columns  | default: 4
            assign item_mega_image    = block.settings.mega_featured_image
            assign item_mega_heading  = block.settings.mega_featured_heading
            assign item_mega_link     = block.settings.mega_featured_link
            assign item_show_desc     = block.settings.mega_show_description
            break
          endif
        endfor
      -%}

      <li>
        {%- if link.links != blank and item_type != 'none' -%}

          {%- if item_type == 'dropdown' -%}
            {%- comment -%} ---- DROPDOWN ---- {%- endcomment -%}
            <header-menu>
              <details id="Details-HeaderMenu-{{ forloop.index }}">
                <summary
                  id="HeaderMenu-{{ link.handle }}"
                  class="header__menu-item list-menu__item link focus-inset"
                >
                  <span {%- if link.child_active %} class="header__active-menu-item"{% endif %}>
                    {{- link.title | escape -}}
                  </span>
                  {{- 'icon-caret.svg' | inline_asset_content -}}
                </summary>
                <ul
                  id="HeaderMenu-MenuList-{{ forloop.index }}"
                  class="header__submenu list-menu list-menu--disclosure color-{{ section.settings.menu_color_scheme }} gradient caption-large motion-reduce global-settings-popup"
                  role="list"
                  tabindex="-1"
                >
                  {%- for childlink in link.links -%}
                    <li>
                      {%- if childlink.links == blank -%}
                        <a
                          id="HeaderMenu-{{ link.handle }}-{{ childlink.handle }}"
                          href="{{ childlink.url }}"
                          class="header__menu-item list-menu__item link link--text focus-inset caption-large{% if childlink.current %} list-menu__item--active{% endif %}"
                          {% if childlink.current %}aria-current="page"{% endif %}
                        >
                          {{ childlink.title | escape }}
                        </a>
                      {%- else -%}
                        <details id="Details-HeaderSubMenu-{{ link.handle }}-{{ childlink.handle }}">
                          <summary
                            id="HeaderMenu-{{ link.handle }}-{{ childlink.handle }}"
                            class="header__menu-item link link--text list-menu__item focus-inset caption-large"
                          >
                            <span>{{ childlink.title | escape }}</span>
                            {{- 'icon-caret.svg' | inline_asset_content -}}
                          </summary>
                          <ul class="header__submenu list-menu motion-reduce">
                            {%- for grandchildlink in childlink.links -%}
                              <li>
                                <a
                                  href="{{ grandchildlink.url }}"
                                  class="header__menu-item list-menu__item link link--text focus-inset caption-large{% if grandchildlink.current %} list-menu__item--active{% endif %}"
                                  {% if grandchildlink.current %}aria-current="page"{% endif %}
                                >
                                  {{ grandchildlink.title | escape }}
                                </a>
                              </li>
                            {%- endfor -%}
                          </ul>
                        </details>
                      {%- endif -%}
                    </li>
                  {%- endfor -%}
                </ul>
              </details>
            </header-menu>

          {%- else -%}
            {%- comment -%} ---- MEGA MENU ---- {%- endcomment -%}
            <header-menu>
              <details id="Details-HeaderMenu-{{ forloop.index }}" class="mega-menu">
                <summary
                  id="HeaderMenu-{{ link.handle }}"
                  class="header__menu-item list-menu__item link focus-inset"
                >
                  <span {%- if link.child_active %} class="header__active-menu-item"{% endif %}>
                    {{- link.title | escape -}}
                  </span>
                  {{- 'icon-caret.svg' | inline_asset_content -}}
                </summary>

                <div
                  id="MegaMenu-Content-{{ forloop.index }}"
                  class="mega-menu__content mega-menu__content--{{ item_mega_layout }} color-{{ section.settings.menu_color_scheme }} gradient motion-reduce global-settings-popup"
                  tabindex="-1"
                >

                  {%- if item_mega_layout == 'featured' -%}
                    {%- comment -%} Featured: image left + columns right {%- endcomment -%}
                    <div class="mega-menu__featured page-width">
                      {%- if item_mega_image != blank -%}
                        <div class="mega-menu__featured-image">
                          <a href="{{ item_mega_link | default: link.url }}">
                            {{ item_mega_image | image_url: width: 600 | image_tag: class: 'mega-menu__featured-img', loading: 'lazy' }}
                          </a>
                          {%- if item_mega_heading != blank -%}
                            <p class="mega-menu__featured-heading">{{ item_mega_heading }}</p>
                          {%- endif -%}
                        </div>
                      {%- endif -%}
                      <ul
                        class="mega-menu__list mega-menu__list--featured{% if link.levels == 1 %} mega-menu__list--condensed{% endif %}"
                        role="list"
                        style="--mega-columns: {{ item_mega_columns }};"
                      >
                        {%- for childlink in link.links -%}
                          <li>
                            <a
                              href="{{ childlink.url }}"
                              class="mega-menu__link mega-menu__link--level-2 link{% if childlink.current %} mega-menu__link--active{% endif %}"
                              {% if childlink.current %}aria-current="page"{% endif %}
                            >
                              {{ childlink.title | escape }}
                            </a>
                            {%- if childlink.links != blank -%}
                              <ul class="list-unstyled" role="list">
                                {%- for grandchildlink in childlink.links -%}
                                  <li>
                                    <a
                                      href="{{ grandchildlink.url }}"
                                      class="mega-menu__link link{% if grandchildlink.current %} mega-menu__link--active{% endif %}"
                                      {% if grandchildlink.current %}aria-current="page"{% endif %}
                                    >
                                      {{ grandchildlink.title | escape }}
                                    </a>
                                  </li>
                                {%- endfor -%}
                              </ul>
                            {%- endif -%}
                          </li>
                        {%- endfor -%}
                      </ul>
                    </div>

                  {%- elsif item_mega_layout == 'fullwidth' -%}
                    {%- comment -%} Full-width banner + links across bottom {%- endcomment -%}
                    <div class="mega-menu__fullwidth">
                      {%- if item_mega_image != blank -%}
                        <div class="mega-menu__fullwidth-banner">
                          <a href="{{ item_mega_link | default: link.url }}">
                            {{ item_mega_image | image_url: width: 1600 | image_tag: class: 'mega-menu__fullwidth-img', loading: 'lazy' }}
                          </a>
                          {%- if item_mega_heading != blank -%}
                            <div class="mega-menu__fullwidth-heading">{{ item_mega_heading }}</div>
                          {%- endif -%}
                        </div>
                      {%- endif -%}
                      <ul
                        class="mega-menu__list mega-menu__list--fullwidth page-width{% if link.levels == 1 %} mega-menu__list--condensed{% endif %}"
                        role="list"
                        style="--mega-columns: {{ item_mega_columns }};"
                      >
                        {%- for childlink in link.links -%}
                          <li>
                            <a
                              href="{{ childlink.url }}"
                              class="mega-menu__link mega-menu__link--level-2 link{% if childlink.current %} mega-menu__link--active{% endif %}"
                              {% if childlink.current %}aria-current="page"{% endif %}
                            >
                              {{ childlink.title | escape }}
                            </a>
                          </li>
                        {%- endfor -%}
                      </ul>
                    </div>

                  {%- else -%}
                    {%- comment -%} Columns (default) or Grid with images {%- endcomment -%}
                    <ul
                      class="mega-menu__list page-width mega-menu__list--{{ item_mega_layout }}{% if link.levels == 1 %} mega-menu__list--condensed{% endif %}"
                      role="list"
                      style="--mega-columns: {{ item_mega_columns }};"
                    >
                      {%- for childlink in link.links -%}
                        <li>
                          {%- if item_mega_layout == 'grid' and childlink.object and childlink.object.featured_image -%}
                            <a href="{{ childlink.url }}" class="mega-menu__grid-item link">
                              {{ childlink.object.featured_image | image_url: width: 400 | image_tag: class: 'mega-menu__grid-img', loading: 'lazy' }}
                            </a>
                          {%- endif -%}
                          <a
                            id="HeaderMenu-{{ link.handle }}-{{ childlink.handle }}"
                            href="{{ childlink.url }}"
                            class="mega-menu__link mega-menu__link--level-2 link{% if childlink.current %} mega-menu__link--active{% endif %}"
                            {% if childlink.current %}aria-current="page"{% endif %}
                          >
                            {{ childlink.title | escape }}
                          </a>
                          {%- if childlink.links != blank -%}
                            <ul class="list-unstyled" role="list">
                              {%- for grandchildlink in childlink.links -%}
                                <li>
                                  <a
                                    id="HeaderMenu-{{ link.handle }}-{{ childlink.handle }}-{{ grandchildlink.handle }}"
                                    href="{{ grandchildlink.url }}"
                                    class="mega-menu__link link{% if grandchildlink.current %} mega-menu__link--active{% endif %}"
                                    {% if grandchildlink.current %}aria-current="page"{% endif %}
                                  >
                                    {{ grandchildlink.title | escape }}
                                  </a>
                                </li>
                              {%- endfor -%}
                            </ul>
                          {%- endif -%}
                        </li>
                      {%- endfor -%}
                    </ul>
                  {%- endif -%}

                </div>
              </details>
            </header-menu>
          {%- endif -%}

        {%- else -%}
          {%- comment -%} No children or item_type == 'none' {%- endcomment -%}
          <a
            id="HeaderMenu-{{ link.handle }}"
            href="{{ link.url }}"
            class="header__menu-item list-menu__item link link--text focus-inset"
            {% if link.current %}aria-current="page"{% endif %}
          >
            <span {%- if link.current %} class="header__active-menu-item"{% endif %}>
              {{- link.title | escape -}}
            </span>
          </a>
        {%- endif -%}
      </li>
    {%- endfor -%}
  </ul>
</nav>
